# Database Configuration for Neon PostgreSQL
# Get your connection strings from https://console.neon.tech

# Pooled Connection (for application use - includes pgbouncer)
# Format: postgresql://user:password@host/database?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://username:password@ep-xxxxx.aws.region.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct Connection (for migrations - without pgbouncer)
# Format: postgresql://user:password@host/database?sslmode=require
DIRECT_URL="postgresql://username:password@ep-xxxxx.aws.region.neon.tech/neondb?sslmode=require"

