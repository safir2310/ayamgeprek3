// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User & Member System
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  phone               String?
  address             String?
  password            String
  memberLevel         String    @default("Bronze") // Bronze, Silver, Gold, Platinum, Crazy Rich
  points              Int       @default(0)
  stampCount          Int       @default(0)
  starCount           Int       @default(0)
  role                String    @default("customer") // customer, admin
  profilePhoto        String?   // Base64 encoded profile photo
  theme               String    @default("light") // light, dark
  notificationSound   String    @default("chime") // chime, bell, whistle, pop, cheer, melody
  profilePrivate       Boolean   @default(false)
  emailNotifications   Boolean   @default(true)
  smsNotifications    Boolean   @default(false)
  language           String    @default("id") // id, en, ar, zh, ja, ko
  termsAcceptedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orders             Order[]
  cartItems          CartItem[]
  pointHistory       PointHistory[]
  voucherUsages      VoucherUsage[]
  pointVouchers      PointVoucher[]
  chatConversations  ChatConversation[]
  menuAccesses       MenuAccess[]
}

// Menu Access Tracking
model MenuAccess {
  id            String    @id @default(cuid())
  userId        String
  menuId        String
  menuName      String?
  accessCount   Int       @default(1)
  lastAccessedAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, menuId])
}

// Product Categories
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

// Products
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Int
  discountPrice Int?
  discountPercent Int?
  promoStartDate DateTime? // Tanggal mulai promo
  promoEndDate   DateTime? // Tanggal berakhir promo
  stock       Int      @default(0)
  barcode     String?  @unique
  image       String?
  categoryId  String
  featured    Boolean  @default(false)
  isPromo     Boolean  @default(false)
  soldCount   Int      @default(0)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  cartItems   CartItem[]
  pointRedemptions PointRedemption[]
}

// Cart Items
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

// Orders
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  customerName    String
  customerPhone   String
  customerAddress String
  totalAmount     Int
  discountAmount  Int         @default(0)
  finalAmount     Int
  paymentMethod   String      // QRIS, COD, Cash
  paymentStatus   String      @default("pending") // pending, paid, verified, rejected, failed
  orderStatus     String      @default("pending") // pending, processing, shipped, completed, cancelled, confirmed
  voucherCode     String?
  pointsEarned    Int         @default(0)
  pointsUsed      Int         @default(0)
  notes           String?
  qrCode          String?
  paymentProof    String?     // Base64 image for payment proof
  transactionDate DateTime?   // Date from payment proof
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User?       @relation(fields: [userId], references: [id])
  items           OrderItem[]
  payments        Payment[]
}

// Order Items
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int
  discount  Int      @default(0)
  subtotal  Int

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

// Payments
model Payment {
  id              String   @id @default(cuid())
  orderId         String
  amount          Int
  paymentMethod   String   // QRIS, Cash
  paymentStatus   String   // pending, paid, failed
  transactionId   String?
  paymentDate     DateTime?
  qrCode          String?
  expiryDate      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Vouchers
model Voucher {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  discountType String  // fixed, percentage
  discountValue Int
  minPurchase Int
  maxDiscount Int?
  startDate   DateTime
  endDate     DateTime
  usageLimit  Int?
  usageCount  Int      @default(0)
  status      String   @default("active") // active, inactive, expired
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usages      VoucherUsage[]
}

// Voucher Usage Tracking
model VoucherUsage {
  id        String   @id @default(cuid())
  voucherId String
  userId    String
  orderId   String
  discount  Int
  usedAt    DateTime @default(now())

  voucher   Voucher  @relation(fields: [voucherId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

// Point Vouchers - Generated from point redemption
model PointVoucher {
  id             String   @id @default(cuid())
  code           String   @unique
  pointsRequired Int
  productId      String
  productName    String?
  productImage   String?
  productPrice   Int?
  userId         String
  isUsed         Boolean  @default(false)
  usedOrderId    String?
  createdAt      DateTime @default(now())
  usedAt         DateTime?

  user           User     @relation(fields: [userId], references: [id])
}

// Point Redemption Options
model PointRedemption {
  id              String   @id @default(cuid())
  name            String
  description     String
  pointsRequired  Int
  productId       String
  productImage    String?
  active          Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product         Product  @relation(fields: [productId], references: [id])
}

// Point History
model PointHistory {
  id        String   @id @default(cuid())
  userId    String
  type      String   // earned, redeemed
  points    Int
  orderId   String?
  description String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// Chat Conversations
model ChatConversation {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?  // Link to order if chat is about specific order
  subject   String?  // Subject/title for the conversation
  status    String   @default("active") // active, closed, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  messages  ChatMessage[]
}

// Chat Messages
model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  senderType     String   // user, admin
  message        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// Admin Settings - Dashboard configuration and preferences
model AdminSettings {
  id                    String   @id @default(cuid())
  storeName             String   @default("Ayam Geprek Store")
  storeDescription      String?
  storeAddress          String?
  storePhone            String?
  storeEmail            String?
  businessHours         String?  // JSON string of business hours
  taxRate              Float    @default(0.11) // 11% tax
  currency              String   @default("IDR")
  pointMultiplier       Float    @default(1.0) // Point earning multiplier
  redemptionMultiplier  Float    @default(1.0) // Point redemption multiplier
  defaultPaymentMethods String   @default("[\"QRIS\",\"Cash\",\"COD\"]") // JSON string array
  enableLoyaltyProgram  Boolean  @default(true)
  loyaltyPointsPerRp    Int      @default(100) // Points per currency unit
  minOrderForPoints     Int      @default(10000) // Minimum order to earn points
  autoApprovePayments   Boolean  @default(false)
  sendNotifications     Boolean  @default(true)
  backupEnabled         Boolean  @default(true)
  lastBackupDate        DateTime?
  dashboardLayout       String?  // JSON string of dashboard layout configuration
  theme                String   @default("light") // light, dark, auto
  language             String   @default("id") // id, en
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
